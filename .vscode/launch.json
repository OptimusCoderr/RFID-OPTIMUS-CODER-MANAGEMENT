{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Server: Debug (tsx)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/server/src/index.ts",
      "cwd": "${workspaceFolder}/server",
      "envFile": "${workspaceFolder}/server/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "restart": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Server: Debug tests (vitest)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["${workspaceFolder}/server/node_modules/vitest/vitest.mjs", "run"],
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Client: Launch Chrome",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client",
      "preLaunchTask": "Client: dev"
    }
  ],
  "compounds": [
    {
      "name": "Full stack: server + client",
      "configurations": ["Server: Debug (tsx)", "Client: Launch Chrome"],
      "stopAll": true
    }
  ]
}
