{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Postgres: start (docker)",
      "type": "shell",
      "command": "docker compose up -d postgres",
      "problemMatcher": []
    },
    {
      "label": "Server: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/server" },
      "problemMatcher": []
    },
    {
      "label": "Server: migrate",
      "type": "shell",
      "command": "npm run prisma:migrate",
      "options": { "cwd": "${workspaceFolder}/server" },
      "problemMatcher": []
    },
    {
      "label": "Server: seed",
      "type": "shell",
      "command": "npm run prisma:seed",
      "options": { "cwd": "${workspaceFolder}/server" },
      "problemMatcher": []
    },
    {
      "label": "Server: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/server" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "dev" },
      "problemMatcher": {
        "pattern": { "regexp": "__never_match__" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "RFID Management API listening"
        }
      }
    },
    {
      "label": "Server: test",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/server" },
      "problemMatcher": []
    },
    {
      "label": "Client: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/client" },
      "problemMatcher": []
    },
    {
      "label": "Client: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/client" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "dev" },
      "problemMatcher": {
        "pattern": { "regexp": "__never_match__" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "Dev: server + client",
      "dependsOn": ["Server: dev", "Client: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
