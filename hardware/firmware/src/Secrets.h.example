#pragma once

// Copy this file to Secrets.h (already in .gitignore) and fill in real
// values. Secrets.h is deliberately not committed.

// --- WiFi (used if Ethernet has no link — see NetworkManager) ---
#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// --- RFID Optimus server ---
// No trailing slash. If your server runs behind TLS termination that
// WebSocketsClient can't verify a cert chain against, terminate TLS at a
// reverse proxy on the same LAN instead of pointing this at a public https
// host directly — see ../README.md.
#define AGENT_SERVER_HOST "192.168.1.50"
#define AGENT_SERVER_PORT 4000

// Issued when the Encoder is registered in the dashboard (Encoders -> Add
// Encoder). Shown once — store it safely, same as the desktop agent's
// AGENT_KEY env var (server/src/agent/agent.ts).
#define AGENT_KEY "REPLACE_WITH_REAL_AGENT_KEY"
