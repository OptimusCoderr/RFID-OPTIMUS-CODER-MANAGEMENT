// RFID / NFC Management System — Prisma schema
// Multi-tenant: every operational record hangs off a Company.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN // platform owner, sees all companies
  COMPANY_ADMIN // full control within their own company
  MANAGER // manage cards/holders/encoders, no user management
  OPERATOR // day-to-day encode/scan operations
  VIEWER // read-only
}

enum CardType {
  MIFARE_CLASSIC_1K
  MIFARE_CLASSIC_4K
  MIFARE_CLASSIC_MINI
  MIFARE_ULTRALIGHT
  MIFARE_ULTRALIGHT_C
  MIFARE_DESFIRE_EV1
  MIFARE_DESFIRE_EV2
  MIFARE_DESFIRE_EV3
  MIFARE_PLUS
  NTAG213
  NTAG215
  NTAG216
  EM4100_125KHZ
  HID_PROX_125KHZ
  T5577_125KHZ
  GENERIC_ISO14443A
  GENERIC_ISO15693
  OTHER
}

enum CardStatus {
  UNASSIGNED
  ACTIVE
  ASSIGNED
  BLOCKED
  LOST
  EXPIRED
  RETIRED
}

enum EncoderType {
  ACR122U
  ACR1252U
  ACR1281U
  PN532
  OMNIKEY_5022
  OMNIKEY_5427
  GENERIC_PCSC
  SERIAL_125KHZ
  OTHER
}

enum EncoderConnectionType {
  USB
  SERIAL
  NETWORK
  BLUETOOTH
}

enum EncoderStatus {
  ONLINE
  OFFLINE
  BUSY
  ERROR
}

enum OperationType {
  READ
  WRITE
  FORMAT
  LOCK
  KEY_CHANGE
  ASSIGN
  UNASSIGN
  BLOCK
  UNBLOCK
  CLONE
  REGISTER
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
}

// NONE = follow the encoder's schedule (daysOfWeek/startTime/endTime).
// FORCE_OPEN / FORCE_CLOSED = manual override that ignores the schedule
// entirely until cleared back to NONE ("resume schedule").
enum ManualOverride {
  NONE
  FORCE_OPEN
  FORCE_CLOSED
}

// Governs what a tap under a given AttendanceSession is allowed to record,
// on top of the normal CHECK_IN/CHECK_OUT alternation — see
// nextAttendanceType in attendanceSessionService.ts for the actual decision
// logic. FREE is the original toggle-forever behavior and stays the
// default so existing schedules are unaffected.
enum AttendanceMode {
  // Unlimited alternating check-in/check-out, same as before this field existed.
  FREE
  // Only ever records a single CHECK_IN per holder per scope; a repeat tap is rejected.
  CHECK_IN_ONLY
  // Only ever records a single CHECK_OUT per holder per scope; a repeat tap is rejected.
  CHECK_OUT_ONLY
  // One check-in then one check-out, in that order; a third tap is rejected.
  ONCE
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum OperationStatus {
  SUCCESS
  FAILED
  PENDING
}

enum NotificationType {
  CARD_EXPIRING
  CARD_EXPIRED
  CARD_BLOCKED
  CARD_LOST
  ENCODER_OFFLINE
  ENCODER_ONLINE
  SYSTEM
}

// What kind of organization a company is — drives the default set of
// modules it starts with (see CompanyModule / industryModules.ts). Optional:
// a company with no industry set is treated as unrestricted (see
// CompanyModule below), matching how every company behaved before this
// concept existed.
enum CompanyIndustry {
  UNIVERSITY
  HOTEL
  BUSINESS
  GOVERNMENT_ID
  INVENTORY
  HEALTHCARE
}

// A slice of the app a company can be granted access to. Gating is
// nav/routing-level on the client — every module's data still lives in the
// same tenant-isolated tables regardless of which modules are enabled.
enum CompanyModule {
  CARDS
  ENCODERS
  TEMPLATES
  HOLDERS
  ZONES
  ATTENDANCE
  LOGS
  // Encrypted National ID-style records (see CitizenRecordLayout) — kept
  // separate from the core modules above since it's specific to
  // e-Government use, not something every industry needs by default.
  CITIZEN_DATA
  // Quick-issue, auto-expiring cards for non-holders (day passes, guest
  // badges) — see VisitorsPage. Reuses the Card model itself (uid, label,
  // expiresAt); no dedicated visitor model.
  VISITORS
  // Service/repair tracking for a card representing a physical asset — see
  // MaintenanceRecord.
  MAINTENANCE
}

// ---------------------------------------------------------------------------
// Core tenancy
// ---------------------------------------------------------------------------

model Company {
  id             String           @id @default(uuid())
  name           String
  slug           String           @unique
  contactEmail   String?
  contactPhone   String?
  address        String?
  logoUrl        String?
  isActive       Boolean          @default(true)
  industry       CompanyIndustry?
  // Empty means unrestricted — every module is available. This is the
  // default for every company created before this feature existed, and for
  // any company created without picking an industry, so nothing changes
  // for existing tenants unless a SUPER_ADMIN explicitly opts them in to
  // module gating (directly, or by picking an industry at creation time).
  enabledModules CompanyModule[]  @default([])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  users              User[]
  holders            CardHolder[]
  encoders           Encoder[]
  cards              Card[]
  templates          CardTemplate[]
  accessZones        AccessZone[]
  operationLogs      OperationLog[]
  notifications      Notification[]
  attendanceRecords  AttendanceRecord[]
  attendanceSessions AttendanceSession[]
  maintenanceRecords MaintenanceRecord[]

  @@map("companies")
}

// Auth is handled by better-auth (see src/auth/index.ts). This model still
// carries the app's own custom fields — role and companyId — used by the
// RBAC middleware exactly as before; better-auth is configured to read/write
// them via additionalFields rather than replacing the multi-tenant model.
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  fullName      String
  image         String?
  role          Role
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  operationLogs           OperationLog[]
  notifications           Notification[]
  sessions                Session[]
  accounts                Account[]
  manualAttendanceRecords AttendanceRecord[]

  @@index([companyId])
  @@map("users")
}

// --- better-auth core tables -----------------------------------------------

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

// Credential (email/password) accounts store their password hash here, one
// row per sign-in method a user has — not on the User record itself.
model Account {
  id                    String    @id @default(uuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

// Generic token store used by better-auth's email/password plugin for
// password-reset tokens (replaces the old PasswordResetToken model).
model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// Signing key pairs for better-auth's jwt plugin (the SPA's bearer JWTs are
// verified against these via JWKS — see src/utils/jwt.ts).
model Jwks {
  id         String    @id @default(uuid())
  publicKey  String
  privateKey String
  alg        String?
  crv        String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@map("jwks")
}

// ---------------------------------------------------------------------------
// People cards get assigned to
// ---------------------------------------------------------------------------

model CardHolder {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fullName   String
  email      String?
  phone      String?
  employeeId String?
  department String?
  photoUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cards             Card[]
  attendanceRecords AttendanceRecord[]

  @@index([companyId])
  @@map("card_holders")
}

// ---------------------------------------------------------------------------
// Encoders / readers / writers
// ---------------------------------------------------------------------------

model Encoder {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name            String
  type            EncoderType
  connectionType  EncoderConnectionType @default(USB)
  serialNumber    String?
  location        String?
  firmwareVersion String?
  agentKey        String                @unique // key the local agent process authenticates with
  status          EncoderStatus         @default(OFFLINE)
  lastSeenAt      DateTime?
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  cardsRegistered    Card[]                  @relation("RegisteredByEncoder")
  operationLogs      OperationLog[]
  cardAllocations    CardEncoderAllocation[]
  attendanceRecords  AttendanceRecord[]
  attendanceSessions AttendanceSession[]
  // Zones this encoder is installed in / controls access to. Purely
  // informational context (e.g. "this reader is the Main Warehouse Floor
  // door") — unlike CardEncoderAllocation, it does not restrict which
  // cards this encoder will accept.
  accessZones        EncoderAccessZone[]

  @@index([companyId])
  @@map("encoders")
}

// ---------------------------------------------------------------------------
// Card templates — define the memory layout / key set applied when encoding
// ---------------------------------------------------------------------------

model CardTemplate {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  cardType    CardType
  description String?
  // MIFARE Classic: per-sector Key A / Key B + access bits.
  // NTAG/Ultralight: page map (start page, page count, purpose).
  // Stored as JSON so the layout stays flexible per card family.
  layout      Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards Card[]

  @@index([companyId])
  @@map("card_templates")
}

// ---------------------------------------------------------------------------
// Physical cards / tags
// ---------------------------------------------------------------------------

model Card {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  uid      String // hex UID as read from the chip
  cardType CardType
  status   CardStatus @default(UNASSIGNED)
  label    String?
  notes    String?

  // Blocks every non-READ encoder command (write/format/lock/key-change/
  // clone/etc — see COMMAND_TO_OPERATION in websocket/index.ts) while still
  // allowing reads, attendance taps, and zone access checks — unlike
  // CardStatus, which either leaves the card fully usable or (via BLOCKED/
  // LOST/RETIRED/EXPIRED) locks it out of lifecycle actions entirely. Opt-in
  // and independent of status, toggled via the dedicated write-protect/
  // write-unprotect endpoints (MANAGER_UP-only, same tier as block/unblock).
  writeProtected Boolean @default(false)

  templateId String?
  template   CardTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  holderId String?
  holder   CardHolder? @relation(fields: [holderId], references: [id], onDelete: SetNull)

  registeredByEncoderId String?
  registeredByEncoder   Encoder? @relation("RegisteredByEncoder", fields: [registeredByEncoderId], references: [id], onDelete: SetNull)

  // Encrypted at the application layer (AES-256-GCM) before storage — never store raw keys.
  keysEncrypted String?
  // Last full memory dump (sectors/pages), non-sensitive, for quick inspection in the UI.
  lastReadData  Json?

  issuedAt   DateTime?
  expiresAt  DateTime?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  accessZones        CardAccessZone[]
  operationLogs      OperationLog[]
  // Encoders this card is allowed to be used with. Empty = unrestricted
  // (usable with any encoder in the company) — allocation is opt-in per card.
  encoderAllocations CardEncoderAllocation[]
  attendanceRecords  AttendanceRecord[]
  maintenanceRecords MaintenanceRecord[]

  @@unique([companyId, uid])
  @@index([companyId])
  @@index([holderId])
  // Range-scanned by the daily expiring-cards job (jobs/expiringCardsJob.ts)
  // and by the Visitors page's hasExpiry list filter — both scan across
  // many cards by this field, unlike the live-encode/attendance expiry
  // checks, which just read it off a single already-fetched-by-id row.
  @@index([expiresAt])
  @@map("cards")
}

// ---------------------------------------------------------------------------
// Access control zones (optional feature: which doors/areas a card opens)
// ---------------------------------------------------------------------------

model AccessZone {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards              CardAccessZone[]
  encoders           EncoderAccessZone[]
  attendanceRecords  AttendanceRecord[]
  attendanceSessions AttendanceSession[]

  @@index([companyId])
  @@map("access_zones")
}

model CardAccessZone {
  id        String     @id @default(uuid())
  cardId    String
  card      Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  zoneId    String
  zone      AccessZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  grantedAt DateTime   @default(now())

  @@unique([cardId, zoneId])
  @@map("card_access_zones")
}

// Which encoder(s) are installed in / control a given zone — informational
// context only (see the `accessZones` comment on Encoder above).
model EncoderAccessZone {
  id        String     @id @default(uuid())
  encoderId String
  encoder   Encoder    @relation(fields: [encoderId], references: [id], onDelete: Cascade)
  zoneId    String
  zone      AccessZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  grantedAt DateTime   @default(now())

  @@unique([encoderId, zoneId])
  @@map("encoder_access_zones")
}

// ---------------------------------------------------------------------------
// Card <-> encoder allocation (optional): restricts which encoder(s) a card
// may be used with. A card with no rows here is unrestricted.
// ---------------------------------------------------------------------------

model CardEncoderAllocation {
  id        String    @id @default(uuid())
  cardId    String
  card      Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  encoderId String
  encoder   Encoder   @relation(fields: [encoderId], references: [id], onDelete: Cascade)
  grantedAt DateTime  @default(now())
  // Optional — e.g. a hotel room key granted only until guest checkout.
  // Null means the grant never expires. An allocation row past this time is
  // NOT treated as "no restriction" (the card still has other/expired rows,
  // so it's clearly meant to be restricted) — see websocket/index.ts.
  expiresAt DateTime?

  @@unique([cardId, encoderId])
  @@map("card_encoder_allocations")
}

// ---------------------------------------------------------------------------
// Attendance (check-in/check-out tap events, e.g. university lecture
// attendance, workplace time tracking). A tap alternates CHECK_IN/CHECK_OUT
// per holder, independently per zone — see attendanceService.ts.
// ---------------------------------------------------------------------------

model AttendanceRecord {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Null only for a manual entry (see manualEntry below) — every tap-based
  // record still requires a real card. onDelete SetNull (not the Cascade a
  // required relation would otherwise imply) so deleting a card doesn't
  // erase its holder's attendance history.
  cardId String?
  card   Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

  // Denormalized from the card at record time — kept even if the card is
  // later reassigned to a different holder, so history stays accurate.
  holderId String?
  holder   CardHolder? @relation(fields: [holderId], references: [id], onDelete: SetNull)

  // Optional: which class/room/session this attendance is scoped to. Null
  // means a general, company-wide check-in/out, tracked independently from
  // any per-zone attendance for the same holder.
  zoneId String?
  zone   AccessZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  encoderId String?
  encoder   Encoder? @relation(fields: [encoderId], references: [id], onDelete: SetNull)

  // Which schedule (see AttendanceSession) was open on the encoder at the
  // moment this tap was recorded, if any — lets attendance be exported or
  // filtered by class/shift (e.g. "CS101" vs "MATH201" on the same shared
  // encoder), not just by encoder or time range. sessionLabel is
  // denormalized from the session at record time, same pattern as
  // holderId above, so exports and filters stay meaningful even after the
  // session is later renamed or deleted; sessionId is kept alongside it
  // for exact filtering while the session still exists.
  sessionId    String?
  session      AttendanceSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionLabel String?

  type       AttendanceType
  recordedAt DateTime       @default(now())

  // A staff-entered record made without a physical tap — e.g. a holder
  // whose card is lost, logged manually until a replacement is issued (see
  // recordManualAttendance in attendanceService.ts). recordedByUserId is
  // who made the call; both are left at their defaults for ordinary taps.
  manualEntry      Boolean @default(false)
  recordedByUserId String?
  recordedByUser   User?   @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([holderId])
  @@index([cardId])
  @@index([zoneId])
  @@index([encoderId])
  @@index([sessionId])
  @@index([recordedAt])
  @@index([recordedByUserId])
  @@map("attendance_records")
}

// A recurring class/shift schedule (e.g. "CS101 Lecture, Mon/Wed/Fri
// 09:00-10:00") plus its own manual override — the "start at will / stop at
// will" buttons on the Attendance page. One encoder can have many of these,
// like a university lecture hall hosting several different courses through
// the week — each schedule is independently named, edited, deleted, and
// started/stopped; encoderId is deliberately NOT unique. Whether a given
// schedule is currently open is computed live from its own fields (see
// computeSessionState in attendanceSessionService.ts), not by a background
// job flipping a stored flag — the same live-check pattern already used for
// Card.expiresAt and CardEncoderAllocation.expiresAt, which avoids a manual
// override being clobbered by the next cron tick. Whether the *encoder* as
// a whole currently accepts a tap is the OR of all its schedules' states
// (see computeEncoderOpenState) — an encoder with zero saved schedules is
// unrestricted, matching every other opt-in restriction in this app.
model AttendanceSession {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  encoderId String
  encoder   Encoder @relation(fields: [encoderId], references: [id], onDelete: Cascade)

  zoneId String?
  zone   AccessZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  // Required — this is the only thing that tells two schedules apart in the
  // saved-schedules table (e.g. "CS101 Lecture" vs "Front Desk Shift"), so a
  // blank one would make that list useless.
  label       String
  description String?

  // 0 = Sunday .. 6 = Saturday. Empty means no recurring schedule is
  // configured (only the manual override applies).
  daysOfWeek Int[]
  // "HH:mm", 24-hour, interpreted in the server's own timezone — this app
  // has no per-company timezone setting, and a schedule is meaningful for
  // one physical encoder in one place.
  startTime  String?
  endTime    String?

  manualOverride ManualOverride @default(NONE)

  // See AttendanceMode — governs what recordAttendance accepts while this
  // schedule is the open one, on top of the usual check-in/out alternation.
  mode AttendanceMode @default(FREE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relation for AttendanceRecord.sessionId — records aren't navigated
  // from here anywhere in the app (exports/filters query AttendanceRecord
  // directly), but Prisma requires the field to declare the relation.
  records AttendanceRecord[]

  @@index([companyId])
  @@index([encoderId])
  @@map("attendance_sessions")
}

// A service/repair ticket against a card representing a physical asset
// (Inventory use case) — kept separate from OperationLog (an immutable
// record of encoder/API actions) since this is a mutable ticket with its
// own lifecycle, not an audit entry.
model MaintenanceRecord {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  description String
  status      MaintenanceStatus @default(OPEN)
  notes       String?

  openedAt   DateTime  @default(now())
  resolvedAt DateTime?

  @@index([companyId])
  @@index([cardId])
  @@index([status])
  @@map("maintenance_records")
}

// ---------------------------------------------------------------------------
// Audit trail
// ---------------------------------------------------------------------------

model OperationLog {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  cardId String?
  card   Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

  encoderId String?
  encoder   Encoder? @relation(fields: [encoderId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  operationType OperationType
  status        OperationStatus
  details       Json?
  errorMessage  String?
  performedAt   DateTime        @default(now())

  @@index([companyId])
  @@index([cardId])
  @@index([performedAt])
  // Covers the Audit Logs page's default view (this company's logs, newest
  // first, no other filter) as a single ordered index scan instead of an
  // index scan on companyId alone followed by a sort.
  @@index([companyId, performedAt])
  // encoderId/userId were previously unindexed despite buildLogWhere
  // (logController.ts) filtering on both — every "show me this encoder's"
  // or "show me this user's" audit trail fell back to scanning the whole
  // company partition.
  @@index([encoderId])
  @@index([userId])
  @@map("operation_logs")
}

// ---------------------------------------------------------------------------
// In-app notifications
// ---------------------------------------------------------------------------

model Notification {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([companyId])
  @@map("notifications")
}
