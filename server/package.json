{
  "name": "rfid-management-server",
  "version": "1.0.0",
  "description": "API + hardware bridge for the RFID/NFC Management System",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "predev": "npm run build:agent",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm run build:agent",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "tsx scripts/withLocalDb.ts -- npx prisma migrate dev",
    "prisma:deploy": "tsx scripts/withLocalDb.ts -- npx prisma migrate deploy",
    "prisma:seed": "tsx scripts/withLocalDb.ts -- npx tsx prisma/seed.ts",
    "prisma:studio": "tsx scripts/withLocalDb.ts -- npx prisma studio",
    "agent": "tsx src/agent/agent.ts",
    "build:agent": "tsc -p tsconfig.agent.json",
    "pretest": "npm run build:agent",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "adm-zip": "^0.5.18",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.6.23",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "prisma": "^6.19.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^11.1.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "nfc-pcsc": "^0.8.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9.9.0",
    "pg": "^8.12.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
