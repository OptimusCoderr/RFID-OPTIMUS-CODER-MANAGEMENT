# If you downloaded this package from the dashboard's "Download agent"
# button, a real .env with these values already filled in is included —
# you can ignore this file. It's only needed if you're setting the agent up
# by hand.

# The RFID/NFC Management System server this agent should connect to.
AGENT_SERVER_URL="https://your-server"

# From the dashboard: Encoders -> Register encoder (or Rotate key). Shown
# once — copy it immediately, it can't be viewed again after you navigate
# away (only re-issued via Rotate key, which invalidates the old one).
AGENT_KEY="paste-your-encoder-agent-key-here"
